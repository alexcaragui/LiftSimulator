@model List<Lift.Data.Models.ProcessInterruption>
@{
    ViewData["Title"] = "Raport Întreruperi";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body>
<nav class="navbar navbar-dark px-4 mb-4" style="background-color:#2c3e50;">
    <span class="navbar-brand">🏗️ Lift Simulator</span>
    <a href="/Home/Index" class="btn btn-outline-light btn-sm">← Înapoi</a>
</nav>

<div class="container">
    <h4 class="mb-4">📊 Raport Întreruperi Proces</h4>

        @if (!Model.Any())
        {
            <div class="alert alert-info">Nu există întreruperi înregistrate.</div>
        }
        else
        {
            <table class="table table-bordered table-hover bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Oprit de</th>
                        <th>Oprit la</th>
                        <th>Repornit de</th>
                        <th>Repornit la</th>
                        <th>Durată</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var durata = item.RestartedAt.HasValue
                            ? (item.RestartedAt.Value - item.StoppedAt).ToString(@"hh\:mm\:ss")
                            : "În curs...";

                            <tr class="@(item.RestartedAt == null ? "table-warning" : "")">
                                <td>@item.Id</td>
                                <td><strong>@(item.StoppedByUser?.Username ?? "-")</strong></td>
                                <td>@item.StoppedAt.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td>@(item.RestartedByUser?.Username ?? "-")</td>
                                <td>@(item.RestartedAt?.ToString("dd/MM/yyyy HH:mm:ss") ?? "-")</td>
                                <td>
                                    <span class="badge @(item.RestartedAt == null ? "bg-warning text-dark" : "bg-success")">
                                    @durata
                                    </span>
                                </td>
                            </tr>
                    }
                </tbody>
            </table>

            <div class="card p-3 mt-3">
                <strong>Total întreruperi: @Model.Count</strong><br />
                <strong>Întreruperi active: @Model.Count(x => x.RestartedAt == null)</strong>
            </div>
        }
</div>
</body>
</html>